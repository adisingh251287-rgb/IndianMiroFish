// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: simulations
// Document ID: simulationId
// Fields:
//   - question: string (required, 1-500 chars)
//   - language: string (required, enum)
//   - status: string (required, enum: idle, initializing, simulating, synthesizing, completed, error)
//   - agents: list (required, max 10 items)
//   - messages: list (required, max 100 items)
//   - synthesis: string (optional, max 5000 chars)
//   - error: string (optional, max 500 chars)
//   - timestamp: number (required)
//   - lastUpdated: number (required)
//   - createdBy: string (optional)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "adisingh251287@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidSimulation(data) {
      return data.question is string && data.question.size() > 0 && data.question.size() <= 500 &&
             data.language is string &&
             data.status in ['idle', 'initializing', 'simulating', 'synthesizing', 'completed', 'error'] &&
             data.agents is list && data.agents.size() <= 10 &&
             data.messages is list && data.messages.size() <= 100 &&
             (!('synthesis' in data) || (data.synthesis is string && data.synthesis.size() <= 5000)) &&
             (!('error' in data) || (data.error is string && data.error.size() <= 500)) &&
             data.timestamp is number &&
             data.lastUpdated is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /simulations/{simulationId} {
      // Simulations are publicly readable if they exist, but only authenticated users can create/update
      // Actually, for real-time collaboration, we want users to be able to join.
      // We'll allow read if authenticated.
      allow read: if isAuthenticated();
      
      allow create: if isAuthenticated() && 
                      hasRequiredFields(['question', 'language', 'status', 'agents', 'messages', 'timestamp', 'lastUpdated']) &&
                      isValidSimulation(request.resource.data);
                      
      allow update: if isAuthenticated() && 
                      isValidSimulation(request.resource.data) &&
                      // Ensure timestamp is immutable
                      request.resource.data.timestamp == resource.data.timestamp;
                      
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
