{
  "entities": {
    "Agent": {
      "title": "Agent",
      "description": "An expert agent in the simulation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "avatar": { "type": "string" },
        "color": { "type": "string" },
        "reputation": { "type": "number" }
      },
      "required": ["id", "name", "role", "avatar", "color", "reputation"]
    },
    "Message": {
      "title": "Message",
      "description": "A message in the debate",
      "type": "object",
      "properties": {
        "agentId": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["agentId", "content", "timestamp"]
    },
    "Simulation": {
      "title": "Simulation",
      "description": "A shared simulation session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "question": { "type": "string" },
        "language": { "type": "string" },
        "status": { "type": "string", "enum": ["idle", "initializing", "simulating", "synthesizing", "completed", "error"] },
        "agents": { "type": "array", "items": { "$ref": "Agent" } },
        "messages": { "type": "array", "items": { "$ref": "Message" } },
        "synthesis": { "type": "string" },
        "error": { "type": "string" },
        "timestamp": { "type": "number" },
        "lastUpdated": { "type": "number" },
        "createdBy": { "type": "string" }
      },
      "required": ["question", "language", "status", "agents", "messages", "timestamp", "lastUpdated"]
    }
  },
  "firestore": {
    "/simulations/{simulationId}": {
      "schema": "Simulation",
      "description": "Shared simulation sessions for real-time collaboration"
    }
  }
}
